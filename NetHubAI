    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Acción al presionar el botón flotante
Button.MouseButton1Click:Connect(function()
    local Character = LocalPlayer.Character
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if not Character or not Backpack then return end

    local Gun = Backpack:FindFirstChild("Gun") or Character:FindFirstChild("Gun")
    if not Gun then
        print("⚠️ No tienes el arma equipada.")
        return
    end

    local ShootRemote = Gun:FindFirstChildOfClass("RemoteEvent")
    if not ShootRemote then
        print("⚠️ No se encontró RemoteEvent de disparo.")
        return
    end

    local MyRoot = Character:FindFirstChild("HumanoidRootPart")
    if not MyRoot then return end

    local Murderer
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if plr.Backpack:FindFirstChild("Knife") or plr.Character:FindFirstChild("Knife") then
                Murderer = plr
                break
            end
        end
    end

    if not Murderer or not Murderer.Character then
        print("😶 No se encontró asesino.")
        return
    end

    local TargetRoot = Murderer.Character:FindFirstChild("HumanoidRootPart")
    if not TargetRoot then return end

    Gun.Parent = Character
    task.defer(function()
        local predicted = TargetRoot.CFrame + (TargetRoot.Velocity * 0.125)
        ShootRemote:FireServer(MyRoot.CFrame, predicted)
        task.wait(0.03)
        Gun.Parent = Backpack
    end)

    print("✅ Disparo automático ejecutado contra:", Murderer.Name)
end)

FloatingShootButton = Button
print("🎯 Botón flotante personalizado creado y movible.")

    end
})

